    "difaryx-workflow-processing-results": "[{\"id\":\"processing-cufe2o4-sba15-xrd-demo\",\"projectId\":\"cufe2o4-sba15\",\"technique\":\"XRD\",\"sourceRoute\":\"/workspace/xrd?project=cufe2o4-sba15\",\"processedAt\":\"2026-04-29T17:30:00.000Z\",\"title\":\"CuFe₂O₄/SBA-15 XRD processing result\",\"sampleId\":\"cufe2o4-sba15\",\"materialSystem\":\"Copper ferrite on mesoporous silica\",\"processedResult\":\"CuFe₂O₄/SBA-15 XRD evidence review\",\"summary\":\"Cross-Technique Fusion Skill: Processed evidence supports CuFe₂O₄ spinel reflections in the supported sample, consistent with dispersed copper ferrite. Phase distribution, loading uniformity, surface oxidation state, and support interaction represent validation-limited scientific claims requiring complementary evidence.\",\"detectedFeatures\":[{\"position\":20.9,\"intensity\":24,\"label\":\"SBA shoulder\"},{\"position\":30.1,\"intensity\":44,\"label\":\"(220)\"},{\"position\":35.5,\"intensity\":77,\"label\":\"(311)\"},{\"position\":43.2,\"intensity\":49,\"label\":\"(400)\"},{\"position\":57.1,\"intensity\":38,\"label\":\"(511)\"}],\"evidenceReview\":[\"XRD Science Skill: Reflections assigned to CuFe₂O₄ remain visible in the supported sample, providing bulk phase indication.\",\"Raman Science Skill: Vibrational modes provide local symmetry indications.\",\"FTIR Science Skill: Silica support features define matrix context but do not independently support phase purity.\"],\"limitations\":[\"Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified.\",\"Validation Boundary Skill: Phase distribution across mesoporous support is not mapped.\",\"Validation Boundary Skill: Surface oxidation state of supported ferrite remains unresolved.\"],\"followUpValidation\":[\"Quantify Cu/Fe ratio from XPS survey scan and compare with nominal loading.\",\"Run TEM-EDX or synchrotron XRD for spatial phase distribution.\",\"XPS high-resolution scan of Cu 2p and Fe 2p regions.\"],\"metrics\":[{\"label\":\"Primary Technique\",\"value\":\"XRD\"},{\"label\":\"Evidence Bundle\",\"value\":\"4 project sources\"},{\"label\":\"Detected Features\",\"value\":\"5\"},{\"label\":\"Evidence State\",\"value\":\"In progress — validation gaps remain\"}],\"workspaceParameters\":{}}]",
