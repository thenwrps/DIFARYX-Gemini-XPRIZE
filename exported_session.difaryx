    "difaryx-workflow-notebook-entries": "[{\"id\":\"notebook-cufe2o4-sba15-research\",\"projectId\":\"cufe2o4-sba15\",\"templateMode\":\"research\",\"templateLabel\":\"Research Mode\",\"refinementId\":\"refinement-processing-cufe2o4-sba15-xrd-demo-research\",\"processingResultId\":\"processing-cufe2o4-sba15-xrd-demo\",\"createdAt\":\"2026-04-29T17:30:00.000Z\",\"title\":\"Research Mode: Refined Discussion\",\"subtitle\":\"Refined from XRD processing result and evidence review\",\"sourceLabel\":\"Source: Processing Result -> Interpretation Refinement -> Notebook Entry\",\"stepperLabels\":[\"Problem\",\"Hypothesis\",\"Processing\",\"Evidence\",\"Mechanism\",\"Claim\",\"Discussion\",\"Manuscript\"],\"tabs\":[\"Interpretation\",\"Evidence\",\"Claim Boundary\",\"Validation\",\"Manuscript\",\"Run Log\"],\"requiredSections\":[\"Refined Discussion\",\"Evidence Status\",\"Claim Boundary\",\"Validation Notes\",\"Manuscript Draft\"],\"statusSummary\":[{\"label\":\"Evidence Status\",\"value\":\"Requires validation\"},{\"label\":\"Claim Readiness\",\"value\":\"Bounded\"},{\"label\":\"Discussion Readiness\",\"value\":\"Publication-limited\"},{\"label\":\"Publication Readiness\",\"value\":\"Publication-limited\"}],\"sections\":[{\"heading\":\"Refined Discussion\",\"lines\":[\"Cross-Technique Fusion Skill: XRD, Raman, and FTIR evidence correlated. Observed signals provide a validation-limited scientific claim of dispersed copper ferrite on SBA-15, with significant validation gaps in loading uniformity and surface states. XRD Science Skill: Reflections assigned to CuFe₂O₄ remain visible in the supported sample, providing bulk phase indication. Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified. Validation Boundary Skill: Phase distribution across mesoporous support is not mapped. Validation Boundary Skill: Surface oxidation state of supported ferrite remains unresolved.\"]},{\"heading\":\"Evidence Status\",\"lines\":[\"Evidence Status: ready with validation requirements.\"]},{\"heading\":\"Claim Boundary\",\"lines\":[\"Supported: XRD Science Skill: Reflections assigned to CuFe₂O₄ remain visible in the supported sample, providing bulk phase indication.\",\"Supported: Raman Science Skill: Vibrational modes provide local symmetry indications.\",\"Supported: FTIR Science Skill: Silica support features define matrix context but do not independently support phase purity.\",\"Contextual: XRD: CuFe₂O₄/SBA-15 XRD\",\"Contextual: XPS: CuFe₂O₄/SBA-15 XPS\",\"Contextual: FTIR: CuFe₂O₄/SBA-15 FTIR\",\"Contextual: Raman: CuFe₂O₄/SBA-15 Raman\",\"Requires validation: Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified.\",\"Requires validation: Validation Boundary Skill: Phase distribution across mesoporous support is not mapped.\",\"Requires validation: Validation Boundary Skill: Surface oxidation state of supported ferrite remains unresolved.\",\"Pending: Complete XPS Cu/Fe ratio quantification\",\"Pending: Compare FTIR silica bands\",\"Not supported yet: Claims beyond CuFe₂O₄ dispersed on mesoporous SBA-15 remain gated by project validation state.\"]},{\"heading\":\"Validation Notes\",\"lines\":[\"Quantify Cu/Fe ratio from XPS survey scan and compare with nominal loading.\",\"Run TEM-EDX or synchrotron XRD for spatial phase distribution.\",\"XPS high-resolution scan of Cu 2p and Fe 2p regions.\"]},{\"heading\":\"Manuscript Draft\",\"lines\":[\"Publication Readiness: publication-limited until validation notes are closed.\"]}],\"reportTemplate\":\"manuscript\",\"workspaceParameters\":{}}]",
    "difaryx-approval-ledger:v1": "{\"entries\":[{\"ledgerId\":\"ledger-49da6845-4209-4eb6-b248-2fd9ef83afa1\",\"timestamp\":\"2026-05-31T06:43:20.899Z\",\"actionId\":\"report-report_export-1780209800898\",\"actionType\":\"report_export\",\"actionLabel\":\"PDF report export\",\"projectId\":\"cufe2o4-sba15\",\"projectName\":\"CuFe₂O₄/SBA-15\",\"sampleIdentity\":\"CuFe₂O₄/SBA-15\",\"bundleId\":\"bundle-cufe2o4-sba15-demo_preloaded-XRD-XPS-FTIR-Raman\",\"sourceMode\":\"demo_preloaded\",\"runtimeMode\":\"demo\",\"permissionMode\":\"read_only\",\"approvalStatus\":\"not_required\",\"decision\":\"local_preview_continued\",\"riskLevel\":\"medium\",\"destinationLabel\":\"Formal report artifact local preview\",\"evidenceSummary\":[\"XRD: XRD Science Skill: CuFe₂O₄-assigned reflections at 30.1°, 35.5°, and 43.2° 2θ remain visible in the SBA-15 supported sample. (Validation Boundary Skill: Phase distribution across mesoporous support is not mapped.)\",\"XPS: XPS Science Skill: Cu 2p and Fe 2p binding energies indicate mixed-oxide surface state; oxidation-state assignment requires peak fitting. (Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified.)\",\"FTIR: FTIR Science Skill: Si–O–Si stretching bands at ~1080 cm⁻¹ confirm SBA-15 matrix; metal–oxygen bands provide contextual evidence.\",\"Raman: Raman Science Skill: Ferrite-like A1g/T2g modes support local spinel symmetry; intensity reduced relative to unsupported bulk.\"],\"validationGaps\":[\"Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified. Resolution: Quantify Cu/Fe ratio from XPS survey scan and compare with nominal loading.\",\"Validation Boundary Skill: Phase distribution across mesoporous support is not mapped. Resolution: Run TEM-EDX or synchrotron XRD for spatial phase distribution.\",\"Validation Boundary Skill: Surface oxidation state of supported ferrite remains unresolved. Resolution: XPS high-resolution scan of Cu 2p and Fe 2p regions.\"],\"claimBoundary\":[\"Supported: XRD Science Skill: Reflections assigned to CuFe₂O₄ remain visible in the supported sample, providing bulk phase indication.\",\"Supported: Raman Science Skill: Vibrational modes provide local symmetry indications.\",\"Supported: FTIR Science Skill: Silica support features define matrix context but do not independently support phase purity.\",\"Requires validation: Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified.\",\"Requires validation: Validation Boundary Skill: Phase distribution across mesoporous support is not mapped.\",\"Requires validation: Validation Boundary Skill: Surface oxidation state of supported ferrite remains unresolved.\"],\"supportedAssignment\":\"CuFe₂O₄ dispersed on mesoporous SBA-15\",\"reviewerLabel\":\"Local demo reviewer\",\"notes\":\"Report local/demo action completed in this browser. No external write executed.\"},{\"ledgerId\":\"ledger-202e2de3-9355-4897-8e57-03ef96e23016\",\"timestamp\":\"2026-05-31T06:43:14.193Z\",\"actionId\":\"agent-notebook_commit-1780209794193\",\"actionType\":\"notebook_commit\",\"actionLabel\":\"Notebook handoff\",\"projectId\":\"cufe2o4-sba15\",\"projectName\":\"CuFe₂O₄/SBA-15\",\"sampleIdentity\":\"CuFe₂O₄/SBA-15\",\"bundleId\":\"bundle-cufe2o4-sba15-demo_preloaded-XRD-XPS-FTIR-Raman\",\"sourceMode\":\"demo_preloaded\",\"runtimeMode\":\"demo\",\"permissionMode\":\"read_only\",\"approvalStatus\":\"not_required\",\"decision\":\"local_preview_continued\",\"riskLevel\":\"low\",\"destinationLabel\":\"Notebook memory handoff preview\",\"evidenceSummary\":[\"XRD: XRD Science Skill: CuFe₂O₄-assigned reflections at 30.1°, 35.5°, and 43.2° 2θ remain visible in the SBA-15 supported sample. (Validation Boundary Skill: Phase distribution across mesoporous support is not mapped.)\",\"XPS: XPS Science Skill: Cu 2p and Fe 2p binding energies indicate mixed-oxide surface state; oxidation-state assignment requires peak fitting. (Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified.)\",\"FTIR: FTIR Science Skill: Si–O–Si stretching bands at ~1080 cm⁻¹ confirm SBA-15 matrix; metal–oxygen bands provide contextual evidence.\",\"Raman: Raman Science Skill: Ferrite-like A1g/T2g modes support local spinel symmetry; intensity reduced relative to unsupported bulk.\"],\"validationGaps\":[\"Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified. Resolution: Quantify Cu/Fe ratio from XPS survey scan and compare with nominal loading.\",\"Validation Boundary Skill: Phase distribution across mesoporous support is not mapped. Resolution: Run TEM-EDX or synchrotron XRD for spatial phase distribution.\",\"Validation Boundary Skill: Surface oxidation state of supported ferrite remains unresolved. Resolution: XPS high-resolution scan of Cu 2p and Fe 2p regions.\"],\"claimBoundary\":[\"Supported: XRD Science Skill: Reflections assigned to CuFe₂O₄ remain visible in the supported sample, providing bulk phase indication.\",\"Supported: Raman Science Skill: Vibrational modes provide local symmetry indications.\",\"Supported: FTIR Science Skill: Silica support features define matrix context but do not independently support phase purity.\",\"Requires validation: Validation Boundary Skill: Ferrite loading uniformity on SBA-15 support is not quantified.\",\"Requires validation: Validation Boundary Skill: Phase distribution across mesoporous support is not mapped.\",\"Requires validation: Validation Boundary Skill: Surface oxidation state of supported ferrite remains unresolved.\"],\"supportedAssignment\":\"CuFe₂O₄ dispersed on mesoporous SBA-15\",\"reviewerLabel\":\"Local demo reviewer\",\"notes\":\"Local deterministic action completed in the frontend demo. No external write executed.\"},{\"ledgerId\":\"ledger-abd9cf38-4382-4e68-8f27-17219b17d51f\",\"timestamp\":\"2026-05-31T06:43:02.314Z\",\"actionId\":\"agent-external_share-1780209782313\",\"actionType\":\"external_share