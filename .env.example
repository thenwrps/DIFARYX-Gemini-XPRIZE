# DIFARYX Agent Demo - Environment Variables

# ============================================================================
# Gemini Developer API Configuration (current mode)
# ============================================================================
# Create a local .env file and set the API key there. GEMINI_API_KEY is read
# only by the root TypeScript server and must never use a VITE_* prefix.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUEST_TIMEOUT_MS=30000
GEMINI_PROVIDER_MODE=developer
GOOGLE_GENAI_USE_VERTEXAI=false

# ============================================================================
# Google Identity Services
# ============================================================================
# Use the same Google Web OAuth client ID in both variables. Client IDs are
# public configuration; they are not API keys or client secrets.

VITE_GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=

# ============================================================================
# Durable Gemini Quota Boundary (server-only)
# ============================================================================
# Upstash provisioning and these private values are manual deployment steps.
# Never add a VITE_* prefix. QUOTA_ID_HASH_SECRET must be independent from the
# Gemini API key and OAuth credentials. Rotating it resets effective user quota
# identities because the HMAC digest changes.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QUOTA_ID_HASH_SECRET=

# Public-beta defaults: 5 per verified user per UTC day and 2 per fixed minute.
GEMINI_USER_DAILY_LIMIT=5
GEMINI_USER_BURST_LIMIT=2
GEMINI_USER_BURST_WINDOW_SECONDS=60

# Mandatory and intentionally has no default. Choose explicitly for deployment.
GEMINI_GLOBAL_DAILY_LIMIT=

# ============================================================================
# Optional future Vertex AI Configuration
# ============================================================================
# To select the optional Vertex mode, replace the current provider mode and
# configure the following values. Vertex uses Application Default Credentials
# and ignores GEMINI_API_KEY.

# GEMINI_PROVIDER_MODE=vertex
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_GENAI_USE_VERTEXAI=true

# ============================================================================
# TypeScript Reasoning Server
# ============================================================================

# Comma-separated browser origins. Set explicit application origins in production.
ALLOWED_ORIGINS=http://localhost:5173
PORT=3001
JSON_BODY_LIMIT=8mb

# ============================================================================
# Gemma Open Model Configuration
# ============================================================================
# Required for the optional Gemma provider (local or hosted).

GEMMA_ENDPOINT=http://localhost:11434/api/generate
GEMMA_MODEL=gemma-2-9b-it

# ============================================================================
# XRD Backend Configuration
# ============================================================================
# Python XRD processing engine (FastAPI).

VITE_XRD_BACKEND_URL=http://localhost:8000

# ============================================================================
# Local Setup Notes
# ============================================================================
# 1. Copy this file to .env and fill private values locally.
# 2. Run npm start for the reasoning server.
# 3. Real Gemini also requires Google identity and complete quota configuration.
# 4. Never commit .env or expose server-only values through frontend variables.
# 5. Vertex AI deployment is optional and deferred while Cloud billing is off.

# ============================================================================
# Database Configuration (Phase 0)
# ============================================================================
# Values are loaded from ignored local configuration or CI secret storage.

DIFARYX_BOOTSTRAP_DATABASE_URL=
DATABASE_URL=
DIFARYX_TEST_DATABASE_URL=
DIFARYX_API_TEST_DATABASE_URL=
DIFARYX_PURGE_TEST_DATABASE_URL=
DIFARYX_ADMIN_TEST_DATABASE_URL=

DIFARYX_API_PASSWORD=
DIFARYX_PURGE_PASSWORD=
DIFARYX_ADMIN_PASSWORD=
DIFARYX_RLS_TEST_PASSWORD=
