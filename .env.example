# DIFARYX Agent Demo - Environment Variables

# ============================================================================
# Google Cloud Vertex AI Configuration
# ============================================================================
# Production authenticates with Application Default Credentials or the
# Cloud Run service account. Do not add API keys or credential files here.

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUEST_TIMEOUT_MS=30000

# ============================================================================
# TypeScript Reasoning Server
# ============================================================================

# Comma-separated browser origins. Set explicit application origins in production.
ALLOWED_ORIGINS=http://localhost:5173
PORT=3001
JSON_BODY_LIMIT=8mb

# ============================================================================
# Gemma Open Model Configuration
# ============================================================================
# Required for the optional Gemma provider (local or hosted).

GEMMA_ENDPOINT=http://localhost:11434/api/generate
GEMMA_MODEL=gemma-2-9b-it

# ============================================================================
# XRD Backend Configuration
# ============================================================================
# Python XRD processing engine (FastAPI).

VITE_XRD_BACKEND_URL=http://localhost:8000

# ============================================================================
# Deployment Notes
# ============================================================================
#
# For Cloud Run deployment:
# 1. Set server environment variables in the Cloud Run service configuration.
# 2. Ensure the service account has Vertex AI User (roles/aiplatform.user).
# 3. Enable the Vertex AI API in the project.
# 4. For Gemma, deploy Ollama or use a hosted endpoint.
#
# For local development:
# 1. Copy this file to .env and replace placeholders locally.
# 2. Use Application Default Credentials for Vertex AI.
# 3. Install Ollama for local Gemma testing: https://ollama.ai
# 4. Run: ollama pull gemma-2-9b-it
#
# Service Account Permissions (for Cloud Run):
# - roles/aiplatform.user (Vertex AI User)
# - roles/logging.logWriter (Cloud Logging)
# - roles/cloudtrace.agent (Cloud Trace, optional)

# ============================================================================
# Database Configuration (Phase 0)
# ============================================================================
# Values are loaded from ignored local configuration or CI secret storage.

DIFARYX_BOOTSTRAP_DATABASE_URL=
DATABASE_URL=
DIFARYX_TEST_DATABASE_URL=
DIFARYX_API_TEST_DATABASE_URL=
DIFARYX_PURGE_TEST_DATABASE_URL=
DIFARYX_ADMIN_TEST_DATABASE_URL=

DIFARYX_API_PASSWORD=
DIFARYX_PURGE_PASSWORD=
DIFARYX_ADMIN_PASSWORD=
DIFARYX_RLS_TEST_PASSWORD=
